# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
INITIAL_ADMIN_TELEGRAM_ID=

# ---- Database (Neon Postgres) ----
# Pooled connection string, used at runtime by the serverless functions
DATABASE_URL=
# Direct (non-pooled) connection string, used only for Prisma migrations
DIRECT_URL=

# ---- Cloudflare R2 (S3-compatible) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
# Only set this if you decide to expose previews publicly via a custom domain/worker.
R2_PUBLIC_BASE_URL=
R2_SIGNED_URL_EXPIRES_SECONDS=900

# ---- Uploads ----
MAX_UPLOAD_SIZE_MB=20

# ---- Cron / backups ----
CRON_SECRET=

# ---- App ----
APP_URL=
NODE_ENV=development

# ---- Admin panel (temporary password auth, replace with Auth.js later) ----
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=
ADMIN_SESSION_SECRET=
